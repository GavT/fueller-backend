# Fueller laptop ingester — environment template.
# Copy to .env in this directory and fill in. Never commit .env.

# ---------- Fuel Finder OAuth2 (required) ----------
# These credentials are issued by the UK government Fuel Finder team.
# Keep them secret. The host running this script must be on the
# Fuel Finder IP allowlist.
FUEL_FINDER_CLIENT_ID=
FUEL_FINDER_CLIENT_SECRET=

# Default points at Fuel Finder staging. Switch to the production base URL
# once the team confirms it.
FUEL_FINDER_BASE_URL=https://stg.fuel-finder.ics.gov.uk

# ---------- Fueller backend (required) ----------
# Where to POST the ingest payload. No trailing slash.
# For the AWS EC2 production deployment, fill in the actual base URL.
BACKEND_URL=https://api.fueller.example.com

# Shared secret. Must equal the INGEST_TOKEN env var on the backend host.
# Generate with: openssl rand -base64 32 | tr -d '=' | tr '/+' '_-'
INGEST_TOKEN=

# ---------- Optional ----------
# Where rotating logs are written (5 MiB x 10 backups).
# Default on Windows: %LOCALAPPDATA%\Fueller\logs
# Default on Linux/macOS: ~/.local/share/fueller/logs
# LOG_DIR=

# Validation thresholds — calibrate after the first real run.
# MIN_STATIONS=1000
# MIN_PRICES=1000
# MIN_LATLON_FRACTION=0.99
