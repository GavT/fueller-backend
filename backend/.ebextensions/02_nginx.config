# Beanstalk's Java platform runs an nginx proxy on port 80 that forwards
# to the app on port 5000. We bump the proxy timeout because the first
# request after deploy can be slow while the cache fills.
files:
  "/etc/nginx/conf.d/proxy.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      proxy_connect_timeout 60s;
      proxy_send_timeout    120s;
      proxy_read_timeout    120s;

container_commands:
  reload_nginx:
    command: "systemctl reload nginx || true"
